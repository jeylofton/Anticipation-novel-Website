# ─── MailerLite (hosted-form endpoint) ─────────────────────────────
# The site posts server-side to MailerLite's hosted-form endpoint:
#   https://assets.mailerlite.com/jsonp/{ACCOUNT_ID}/forms/{FORM_ID}/subscribe
# Neither of these is secret — they appear in any embedded form's code.

# Your MailerLite account ID (the number after /jsonp/ in the embed URL).
MAILERLITE_ACCOUNT_ID=2317102

# The form ID new subscribers are added to. Joining this form is what triggers
# the automation/autoresponder that delivers the Prologue PDF (see README).
MAILERLITE_FORM_ID=186570774851618298

# ─── Plausible Analytics ───────────────────────────────────────────
# The domain registered in Plausible (no protocol). Leave blank to disable
# analytics entirely (the script simply won't load).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=anticipation-novel.com

# ─── Site ──────────────────────────────────────────────────────────
# Canonical absolute URL — used for metadata, Open Graph, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://anticipation-novel.com
